---
import BrandLayout from "../layouts/BrandLayout.astro";

const services = [
  {
    title: "AI Strategy & Build",
    desc: "I architect and ship AI systems that run real operations — voice agents, automations, and multi-agent platforms. Done-with-you or done-for-you.",
    href: "/services#build",
    icon: "⚙️",
  },
  {
    title: "Workshops & Training",
    desc: "Hands-on sessions that take your team from “AI-curious” to shipping. Half-day to multi-day, built around your actual workflows.",
    href: "/services#training",
    icon: "🎓",
  },
];

const stats = [
  { value: "3", label: "Platforms shipped" },
  { value: "4", label: "Free & open-source tools" },
  { value: "10+", label: "AI systems built" },
  { value: "24/7", label: "Agents running real businesses" },
];

// Featured projects, framed as "originals" (logo shown when available; text mark otherwise).
const featuredProjects = [
  { ep: "EP.01", category: "PLATFORM", name: "AgentlandOS", tagline: "AI agents that run a business", logo: "/project-logos/agentland-logo.png", href: "/work#agentlandos" },
  { ep: "EP.02", category: "DEV TOOL", name: "TraceTrack", tagline: "GitHub for AI workflows", logo: null, href: "/work#tracetrack" },
  { ep: "EP.03", category: "QUANT", name: "Trading System", tagline: "Agent-based market signals", logo: "/project-logos/trading-logo.png", href: "/work#trading-system" },
];

// Scrolling marquee strip (broadcast/editorial motif)
const marqueeItems = [
  "AI SYSTEMS", "VOICE AGENTS", "AUTOMATIONS", "REAL-TIME PLATFORMS",
  "DASHBOARDS", "FREE TOOLS", "BUILT IN DETROIT", "25M+ VIEWS",
];

const testimonials = [
  {
    quote:
      "Zach doesn’t just talk about AI — he builds the thing and shows you the dashboard. We went from idea to a working agent in days.",
    name: "Operations Lead",
    org: "Local Services Business",
  },
  {
    quote:
      "The most practical AI session our team has had. No buzzwords, just systems we actually use now.",
    name: "Founder",
    org: "Detroit Startup",
  },
  {
    quote:
      "He gets that AI is only useful if it runs without you babysitting it. That mindset changed how we operate.",
    name: "Small Business Owner",
    org: "Service Company",
  },
];
---

<BrandLayout active="home">
  <!-- HERO / SHOWREEL -->
  <section class="border-b border-ink">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 md:py-20 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div>
        <span class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-ink/60 mb-6">
          <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
          Zachary Lewis — a one-person media co.
        </span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-black uppercase tracking-tight text-ink leading-[1.05]">
          I build and design AI systems that
          <span class="text-accent"> change the way you work.</span>
        </h1>
        <p class="mt-6 text-lg md:text-xl text-ink/80 leading-relaxed max-w-xl">
          I integrate AI into real projects. I work with founders and creative teams to design,
          build, and ship systems that actually do the work — not demos, not decks.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href="/work" class="group px-6 py-3.5 bg-accent text-white border border-ink font-bold text-center hover:shadow-lg transition-all inline-flex items-center justify-center gap-2">
            <span class="text-lg leading-none">▶</span> Watch the Work
          </a>
          <a href="/contact" class="px-6 py-3.5 border border-ink text-ink font-bold text-center hover:bg-paper2 transition-colors">
            Work With Me
          </a>
        </div>
      </div>

      <!-- Showreel player (drop a video in below) -->
      <figure class="border border-ink bg-ink shadow-xl">
        <!-- top bar -->
        <div class="flex items-center justify-between px-3 py-2 border-b border-paper/20 font-mono text-[10px] uppercase tracking-widest text-paper/60">
          <span class="inline-flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span> REC · REEL 2026</span>
          <span>16:9</span>
        </div>
        <div class="relative aspect-video w-full overflow-hidden group">
          <!-- Replace this placeholder with a <video> or <img>:
               <video src="/hero.mp4" autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover"></video> -->
          <div class="absolute inset-0 flex items-center justify-center bg-ink">
            <span class="font-mono text-[10px] uppercase tracking-widest text-paper/30">[ drop showreel here ]</span>
          </div>
          <!-- play button -->
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="w-16 h-16 rounded-full bg-accent text-white border border-paper/30 flex items-center justify-center text-2xl pl-1 group-hover:scale-110 transition-transform">▶</span>
          </div>
        </div>
        <!-- scrubber -->
        <figcaption class="flex items-center gap-3 px-3 py-2 border-t border-paper/20 font-mono text-[10px] text-paper/60">
          <span>00:00</span>
          <span class="flex-1 h-1 bg-paper/15 relative overflow-hidden"><span class="absolute inset-y-0 left-0 w-1/4 bg-accent"></span></span>
          <span>02:14</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee bg-ink text-paper border-b border-ink py-3">
    <div class="marquee__track font-mono text-sm uppercase tracking-widest">
      {[...marqueeItems, ...marqueeItems].map((m) => (
        <span class="mx-6 inline-flex items-center gap-6"><span>{m}</span><span class="text-accent">✦</span></span>
      ))}
    </div>
  </div>

  <!-- BY THE NUMBERS + ORIGINALS (one section) -->
  <section class="border-b border-ink bg-paper2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <!-- stats -->
      <p class="font-mono text-[11px] uppercase tracking-widest text-ink/50 mb-6">// By the numbers</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map((s) => (
          <div>
            <div class="text-4xl md:text-5xl font-black tracking-tight text-ink">{s.value}</div>
            <div class="text-sm md:text-base font-medium text-ink/70 mt-1.5">{s.label}</div>
          </div>
        ))}
      </div>

      <!-- originals -->
      <div class="flex items-end justify-between mb-8 mt-16 md:mt-20">
        <h2 class="font-mono text-[11px] uppercase tracking-widest text-ink/50">// Originals</h2>
        <a href="/work" class="font-mono text-[11px] uppercase tracking-widest text-accent hover:text-accent-dark">All work →</a>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
      {featuredProjects.map((p) => (
        <a href={p.href} class="group no-underline border border-ink bg-white hover:shadow-lg transition-all">
          <!-- thumbnail / channel-bug -->
          <div class="relative aspect-video w-full overflow-hidden border-b border-ink bg-paper2 flex items-center justify-center">
            {p.logo ? (
              <img src={p.logo} alt={`${p.name}`} class="max-h-20 max-w-[70%] object-contain" loading="lazy" />
            ) : (
              <span class="text-2xl font-black tracking-tight text-accent">{p.name}</span>
            )}
            <span class="absolute top-2 left-2 font-mono text-[10px] uppercase tracking-widest text-ink/50">{p.ep}</span>
            <span class="absolute bottom-2 right-2 w-9 h-9 rounded-full bg-accent text-white flex items-center justify-center text-sm pl-0.5 opacity-0 group-hover:opacity-100 transition-opacity">▶</span>
          </div>
          <div class="p-4">
            <span class="font-mono text-[10px] uppercase tracking-widest text-accent">{p.category}</span>
            <h3 class="mt-1 font-bold text-ink group-hover:text-accent transition-colors">{p.name}</h3>
            <p class="mt-1 text-sm text-ink/60">{p.tagline}</p>
          </div>
        </a>
      ))}
      </div>
    </div>
  </section>

  <!-- BIO -->
  <section class="border-y border-ink bg-paper2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 grid md:grid-cols-5 gap-10 items-center">
      <div class="md:col-span-2">
        <div class="aspect-square w-full max-w-sm rounded-2xl overflow-hidden border border-ink bg-paper2">
          <img src="/profile-photo.jpg" alt="Zachary Lewis" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
      <div class="md:col-span-3">
        <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4">From video to AI operator</h2>
        <p class="text-ink/80 leading-relaxed mb-4">
          I spent years building a video production business — growing an audience of 100K+ followers and 25M+ views.
          In 2024 I went all-in on AI, and I haven't stopped building since: voice agents, mobile apps, real-time
          platforms, and an operating system that runs my own businesses.
        </p>
        <p class="text-ink/60 leading-relaxed mb-6">
          I learn by doing and ship fast. That means when I help you, you get working systems — not slide decks.
        </p>
        <a href="/about" class="inline-block px-5 py-3 rounded-xl border border-ink text-ink font-semibold hover:bg-paper2 transition-colors">
          More about me
        </a>
      </div>
    </div>
  </section>

  <!-- HOW I CAN HELP + PROOF / TOOLS -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
    <div class="max-w-2xl mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-ink">How I can help</h2>
      <p class="mt-3 text-ink/60 text-lg">Two ways to put applied AI to work in your business.</p>
    </div>
    <div class="grid gap-6 md:grid-cols-2">
      {services.map((s) => (
        <a href={s.href} class="group block no-underline rounded-2xl border border-ink bg-white p-8 hover:border-accent hover:bg-white transition-all">
          <div class="text-3xl mb-4">{s.icon}</div>
          <h3 class="text-xl font-bold text-ink mb-2 group-hover:text-accent transition-colors">{s.title}</h3>
          <p class="text-ink/60 text-sm leading-relaxed">{s.desc}</p>
          <span class="mt-4 inline-block text-sm font-semibold text-accent group-hover:translate-x-1 transition-transform">Learn more →</span>
        </a>
      ))}

      <div class="rounded-2xl border border-ink bg-white p-8 flex flex-col hover:border-accent transition-all">
        <span class="text-xs font-semibold uppercase tracking-wider text-accent mb-3">The proof</span>
        <h3 class="text-xl font-bold text-ink mb-2">Real systems I've shipped</h3>
        <p class="text-ink/60 text-sm leading-relaxed flex-1">
          AgentlandOS, TraceTrack, an agent-based trading system — software that handles real work, not slideware.
        </p>
        <a href="/work" class="mt-6 inline-block text-sm font-semibold text-accent hover:translate-x-1 transition-transform w-fit">See my work →</a>
      </div>
      <div class="rounded-2xl border border-ink bg-accent/10 p-8 flex flex-col hover:border-accent transition-all">
        <span class="text-xs font-semibold uppercase tracking-wider text-accent mb-3">Free, no signup</span>
        <h3 class="text-xl font-bold text-ink mb-2">Try my tools</h3>
        <p class="text-ink/80 text-sm leading-relaxed flex-1">
          Open-source utilities and free tools — including the <strong>USER.md generator</strong> that gives any AI assistant your full context in one file.
        </p>
        <a href="/tools" class="mt-6 inline-block text-sm font-semibold text-accent hover:translate-x-1 transition-transform w-fit">Browse free tools →</a>
      </div>
    </div>
  </section>

  {/* TESTIMONIALS — hidden for now, kept for later
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28 pt-0">
    <h2 class="text-3xl md:text-4xl font-bold text-ink text-center mb-12">What people say</h2>
    <div class="grid gap-6 md:grid-cols-3">
      {testimonials.map((t) => (
        <figure class="rounded-2xl border border-ink bg-white p-7">
          <div class="text-accent text-3xl leading-none mb-3">&ldquo;</div>
          <blockquote class="text-ink/80 text-sm leading-relaxed">{t.quote}</blockquote>
          <figcaption class="mt-5 pt-5 border-t border-ink">
            <div class="font-semibold text-ink text-sm">{t.name}</div>
            <div class="text-ink/50 text-xs">{t.org}</div>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
  */}

  {/* FAKE MONEY — saved, hidden for now
  <section class="border-t border-ink">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
      <div class="rounded-3xl bg-accent/10 border border-ink p-8 md:p-12">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <span class="inline-block text-xs font-semibold uppercase tracking-wider text-accent mb-3">Fake Money</span>
            <h2 class="text-2xl md:text-3xl font-bold text-ink mb-3">Follow my journey to make money with AI</h2>
            <p class="text-ink/80 leading-relaxed mb-5">
              <strong>Fake Money</strong> — an AI trading platform that analyzes, never auto-fires.
            </p>
            <ul class="space-y-2 text-sm text-ink/80 mb-6">
              <li class="flex gap-2"><span>🧠</span> Agents read companies and live charts to call the signals</li>
              <li class="flex gap-2"><span>🛡️</span> Every order clears a risk pipeline — no entry without a stop</li>
              <li class="flex gap-2"><span>🎚️</span> Autonomous execution off by default — you stay in control</li>
            </ul>
            <p class="text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2">What you'll need to run it</p>
            <ul class="space-y-2 text-sm text-ink/80">
              <li class="flex gap-2"><span class="text-accent">→</span> A <span class="font-medium">tastytrade</span> brokerage account</li>
              <li class="flex gap-2"><span class="text-accent">→</span> Your own LLM API keys — Gemini's free tier works,
                <a href="https://aistudio.google.com/app/apikey" target="_blank" rel="noopener noreferrer" class="text-accent font-medium hover:text-accent-dark">grab keys from the Gemini dashboard ↗</a>
              </li>
            </ul>
          </div>
          <div>
            <form name="journey" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you" class="space-y-3">
              <input type="hidden" name="form-name" value="journey" />
              <input type="text" name="name" placeholder="Your name" required class="w-full px-4 py-3 rounded-xl bg-white border border-ink text-ink placeholder-ink/40 focus:outline-none focus:border-accent" />
              <input type="email" name="email" placeholder="you@email.com" required class="w-full px-4 py-3 rounded-xl bg-white border border-ink text-ink placeholder-ink/40 focus:outline-none focus:border-accent" />
              <button type="submit" class="w-full px-6 py-3.5 rounded-xl bg-accent text-white border border-ink font-semibold hover:opacity-90 transition-opacity">Follow the journey</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
  */}

  <!-- FEATURED CAROUSEL -->
  <section class="border-t border-ink">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="flex items-end justify-between mb-6">
        <h2 class="font-mono text-[11px] uppercase tracking-widest text-ink/50">// Featured</h2>
        <div class="flex gap-2">
          <button id="promo-prev" aria-label="Previous" class="w-10 h-10 rounded-full border border-ink text-ink flex items-center justify-center hover:bg-paper2 transition-colors">←</button>
          <button id="promo-next" aria-label="Next" class="w-10 h-10 rounded-full border border-ink text-ink flex items-center justify-center hover:bg-paper2 transition-colors">→</button>
        </div>
      </div>

      <div id="promo-track" class="flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <!-- Slide 1: USER.md -->
        <a href="/tools/user-md" class="snap-start shrink-0 w-full no-underline">
          <div class="border border-ink overflow-hidden bg-paper2">
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-ink font-mono text-[10px] md:text-[11px] uppercase tracking-widest">
              <span class="text-accent">USER.md · Free tool</span>
              <span class="text-ink/50">No signup · Build yours →</span>
            </div>
            <div class="aspect-[4/3] md:aspect-[3/2] w-full flex items-center justify-center overflow-hidden">
              <img src="/user-md-cta.png" alt="USER.md — one file that gives any AI your full context" class="w-full h-full object-contain" loading="lazy" />
            </div>
          </div>
        </a>

        <!-- Slide 2: Agentland (custom card) -->
        <a href="https://agentlandos.com" target="_blank" rel="noopener noreferrer" class="snap-start shrink-0 w-full no-underline">
          <div class="border border-ink overflow-hidden bg-zinc-950">
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-zinc-800 font-mono text-[10px] md:text-[11px] uppercase tracking-widest">
              <span class="text-purple-300">AgentlandOS · Platform</span>
              <span class="text-zinc-500">agentlandos.com ↗</span>
            </div>

            <div class="relative aspect-[4/3] md:aspect-[3/2] w-full overflow-hidden p-6 md:p-10 flex flex-col items-start justify-center text-left">
              <!-- ambient glows + grid -->
              <div class="absolute -top-16 -right-12 w-64 h-64 rounded-full bg-purple-600/30 blur-3xl"></div>
              <div class="absolute -bottom-20 -left-12 w-64 h-64 rounded-full bg-pink-600/20 blur-3xl"></div>
              <div class="absolute inset-0 opacity-[0.06]" style="background-image:linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px);background-size:40px 40px;"></div>

              <!-- giant wordmark + super-sized tagline -->
              <h3 class="relative font-black text-white tracking-tight leading-[0.85]" style="font-size:clamp(3rem,15vw,10rem);">Agentland</h3>
              <p class="relative mt-2 md:mt-4 font-bold text-zinc-200 leading-[0.95]" style="font-size:clamp(2rem,10vw,6.5rem);">AI agents that operate your business</p>
              <span class="relative mt-6 md:mt-8 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-pink-600 to-purple-600 text-white font-semibold text-sm">
                Visit AgentlandOS →
              </span>
            </div>
          </div>
        </a>
      </div>

      <!-- dots -->
      <div class="flex justify-center gap-2 mt-5">
        <button data-promo-dot aria-label="Go to slide 1" class="w-2.5 h-2.5 rounded-full bg-ink transition-colors"></button>
        <button data-promo-dot aria-label="Go to slide 2" class="w-2.5 h-2.5 rounded-full bg-ink/25 transition-colors"></button>
      </div>
    </div>
  </section>

  <script>
    const track = document.getElementById("promo-track");
    if (track) {
      const dots = Array.from(document.querySelectorAll("[data-promo-dot]"));
      const go = (i) => track.scrollTo({ left: track.clientWidth * i, behavior: "smooth" });
      document.getElementById("promo-prev")?.addEventListener("click", () =>
        track.scrollBy({ left: -track.clientWidth, behavior: "smooth" })
      );
      document.getElementById("promo-next")?.addEventListener("click", () =>
        track.scrollBy({ left: track.clientWidth, behavior: "smooth" })
      );
      dots.forEach((d, i) => d.addEventListener("click", () => go(i)));
      track.addEventListener("scroll", () => {
        const i = Math.round(track.scrollLeft / track.clientWidth);
        dots.forEach((d, k) => {
          d.classList.toggle("bg-ink", k === i);
          d.classList.toggle("bg-ink/25", k !== i);
        });
      });
    }
  </script>

  {/* FINAL CTA — hidden for now, kept for later
  <section class="border-t border-ink bg-paper2">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4">Ready to put AI to work?</h2>
      <p class="text-ink/60 text-lg mb-8">Tell me what you're trying to build or automate. I'll tell you the fastest path to a working system.</p>
      <a href="/contact" class="inline-block px-8 py-4 rounded-xl bg-accent text-white border border-ink font-semibold text-lg hover:opacity-90 transition-opacity">
        Start the conversation
      </a>
    </div>
  </section>
  */}
</BrandLayout>
