---
import BrandLayout from "../../layouts/BrandLayout.astro";

const REPO_URL = "https://github.com/taketaketaketake/AgentlandOS-media"; // verify

const features = [
  { icon: "⬇️", title: "Download by URL", desc: "Point it at a video URL and it pulls the file with yt-dlp — reels, clips, full videos." },
  { icon: "🎚️", title: "Pick your quality", desc: "best, 1080p, 720p, or audio-only — request the exact format you need." },
  { icon: "🔎", title: "Media probe", desc: "ffprobe metadata on every file: duration, resolution, codecs, framerate, chapters." },
  { icon: "🖼️", title: "Frame & chapter extraction", desc: "Pull keyframes at specific timestamps and extract chapter markers automatically." },
  { icon: "🛡️", title: "Guardrails built in", desc: "Domain allowlist, max filesize, and operation timeouts — fail-closed by default." },
  { icon: "⚡", title: "Async & concurrency-capped", desc: "Subprocess operations run async with a per-instance concurrency limit, plus R2 artifact storage." },
];

const downloadReq = `POST /download
{
  "url": "https://www.youtube.com/watch?v=...",
  "format": "best",          // best | 1080p | 720p | audio_only
  "extract_chapters": true,
  "extract_frames_at": [1.0, 12.5, 30.0]
}`;
---

<BrandLayout theme="dark" active="tools" title="Video Downloader — Grab Any Video by URL | Zachary Lewis" description="An open-source FastAPI media service that downloads videos by URL with yt-dlp — choose quality, probe metadata, extract frames and chapters.">
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-zinc-800">
    <div class="absolute inset-0 bg-transparent"></div>
    <div class="absolute -top-24 -right-24 w-96 h-96 hidden"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 py-20 md:py-28 text-center">
      <span class="inline-flex items-center gap-2 bg-zinc-900/40 border border-zinc-800 rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-pink-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        Open source · Free
      </span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black tracking-tight text-white leading-[1.05]">
        Grab any video. <span class="text-pink-400">By URL.</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-zinc-300 max-w-2xl mx-auto leading-relaxed">
        A media service that wraps <strong>yt-dlp</strong> and <strong>ffprobe</strong>. Hand it a URL and it returns
        the downloaded file plus full metadata — in the quality you ask for.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="#quick-start" class="px-7 py-3.5 rounded-xl bg-gradient-to-r from-pink-600 to-purple-600 text-white font-semibold hover:opacity-90 transition-opacity">⚡ Quick start</a>
        <a href={REPO_URL} target="_blank" rel="noopener noreferrer" class="px-7 py-3.5 rounded-xl border border-zinc-800 text-white font-semibold hover:bg-zinc-800/50 transition-colors">View on GitHub →</a>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <h2 class="text-3xl font-bold text-white mb-10">What it does</h2>
    <div class="grid gap-6 md:grid-cols-3">
      {features.map((f) => (
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-7">
          <div class="text-3xl mb-3">{f.icon}</div>
          <h3 class="text-lg font-bold text-white mb-2">{f.title}</h3>
          <p class="text-zinc-400 text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- QUICK START -->
  <section id="quick-start" class="scroll-mt-20 border-y border-zinc-800 bg-zinc-900/40">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <h2 class="text-3xl font-bold text-white mb-3">Quick start</h2>
      <p class="text-zinc-400 mb-8">It's a FastAPI service (Python). Run it with Docker, then POST a URL.</p>

      <div class="rounded-2xl border border-zinc-800 bg-black/60 overflow-hidden mb-6">
        <div class="px-4 py-2.5 border-b border-zinc-800 bg-zinc-900/40 text-xs font-mono text-zinc-400">terminal</div>
        <pre class="p-4 text-sm font-mono text-white overflow-x-auto leading-relaxed"><span class="text-zinc-600"># start the service</span>
docker compose up</pre>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-black/60 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-zinc-800 bg-zinc-900/40 text-xs font-mono text-zinc-400">request</div>
        <pre class="p-4 text-xs sm:text-sm font-mono text-white overflow-x-auto leading-relaxed">{downloadReq}</pre>
      </div>
      <p class="text-sm text-zinc-500 mt-4">Returns an <code class="text-zinc-300">artifact_uri</code> for the downloaded file, ffprobe metadata, and any extracted frame URIs.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-24 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Free and open source.</h2>
    <p class="text-zinc-400 text-lg mb-8">Grab it on GitHub — or if you want media tooling built into your own platform, let's talk.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href={REPO_URL} target="_blank" rel="noopener noreferrer" class="px-7 py-3.5 rounded-xl bg-gradient-to-r from-pink-600 to-purple-600 text-white font-semibold hover:opacity-90 transition-opacity">View on GitHub</a>
      <a href="/contact" class="px-7 py-3.5 rounded-xl border border-zinc-800 text-white font-semibold hover:bg-zinc-800/50 transition-colors">Work with me</a>
    </div>
    <p class="mt-8 text-sm text-zinc-500"><a href="/tools" class="hover:text-zinc-300 transition-colors">← Back to all free tools</a></p>
  </section>
</BrandLayout>
