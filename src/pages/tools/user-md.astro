      aiknow: () => `## Things the AI Should Know

${g("f-aiknow")}`,

      opmanual: () => `## Personal Operating Manual

- **What Motivates Me:** ${g("pom-motivates")}
- **What Frustrates Me:** ${g("pom-frustrates")}
- **What Success Looks Like:** ${g("pom-success")}
- **What I Want More Of:** ${g("pom-more")}
- **What I Want Less Of:** ${g("pom-less")}`,
    };

    // Order in the file → toggle key that controls it.
    // "aiknow" and "opmanual" share the Personal Operating Manual toggle.
    const order = [
      ["identity", "identity"],
      ["priorities", "priorities"],
      ["longgoals", "longgoals"],
      ["background", "background"],
      ["skills", "skills"],
      ["interests", "interests"],
      ["preferences", "preferences"],
      ["constraints", "constraints"],
      ["values", "values"],
      ["tools", "tools"],
      ["guidelines", "guidelines"],
      ["aiknow", "opmanual"],
      ["opmanual", "opmanual"],
    ];

    const HEADER = `# USER.md

## Purpose

This file provides foundational context about the user. Any AI assistant, agent, or software system should review this file before providing recommendations, creating plans, writing content, building projects, or making decisions on the user's behalf.`;

    const FOOTER = `## Default Instruction

Use the information in this file to personalize recommendations, plans, explanations, and decisions. Maintain consistency with the user's goals, preferences, constraints, and values. When uncertainty exists, ask questions rather than making assumptions.`;

    function buildMarkdown() {
      const parts = [HEADER];
      for (const [sectionKey, toggleKey] of order) {
        if (on(toggleKey)) parts.push(sections[sectionKey]());
      }
      parts.push(FOOTER);
      return parts.join("\n\n---\n\n") + "\n";
    }

    function render() {
      preview.textContent = buildMarkdown();
    }

    const allToggles = () => Array.from(document.querySelectorAll(".section-toggle"));
    const dim = (t) => {
      const wrap = t.closest("details") || t.closest("div");
      if (wrap) wrap.classList.toggle("opacity-50", !t.checked);
    };

    // Section toggles: don't let the switch open/close the <details>, and dim excluded sections.
    allToggles().forEach((t) => {
      t.addEventListener("change", () => {
        dim(t);
        render();
      });
      const label = t.closest(".section-toggle-wrap");
      if (label) label.addEventListener("click", (e) => e.stopPropagation());
      dim(t); // initial state (minimal by default)
    });

    // Presets
    const MINIMAL = ["identity", "priorities", "preferences", "guidelines"];
    function applyPreset(keys) {
      allToggles().forEach((t) => {
        const key = t.getAttribute("data-toggle");
        t.checked = keys === "all" ? true : keys.includes(key);
        dim(t);
      });
      render();
    }
    document.getElementById("preset-minimal").addEventListener("click", () => applyPreset(MINIMAL));
    document.getElementById("preset-full").addEventListener("click", () => applyPreset("all"));

    form.addEventListener("input", render);
    form.addEventListener("change", render);
    render();

    // Copy
    const copyBtn = document.getElementById("copy-btn");
    copyBtn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(buildMarkdown());
        const orig = copyBtn.textContent;
        copyBtn.textContent = "Copied!";
        setTimeout(() => (copyBtn.textContent = orig), 1500);
      } catch (e) {
        copyBtn.textContent = "Press Ctrl+C";
      }
    });

    // Download
    document.getElementById("download-btn").addEventListener("click", () => {
      const blob = new Blob([buildMarkdown()], { type: "text/markdown;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "USER.md";
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
  </script>
</BrandLayout>
