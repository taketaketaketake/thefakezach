---
import BrandLayout from "../../layouts/BrandLayout.astro";

const REPO_URL = "#"; // TODO: drop in the GitHub URL

const features = [
  { icon: "📡", title: "Live event feed", desc: "Every hook — tool use, sessions, permissions — streamed in real time with per-agent color coding and swim lanes." },
  { icon: "🟢", title: "Agent status panel", desc: "See which agents are active, idle, or stopped across both Claude Code and Gemini CLI, side by side." },
  { icon: "📜", title: "Session transcripts", desc: "Full transcripts ingested at session end and viewable from multiple entry points in the dashboard." },
  { icon: "🙋", title: "Human-in-the-loop", desc: "Respond to agent questions directly from the dashboard — no jumping back to the terminal." },
  { icon: "📊", title: "Insights dashboard", desc: "KPIs, event breakdowns, and tool-usage charts so you can spot patterns across sessions." },
  { icon: "🧪", title: "LLM evaluation", desc: "Score agent quality on tool success, transcript quality, reasoning depth, and statistical regression." },
];

const evaluators = [
  { name: "Tool Success", desc: "Tool success/failure rate — no API key needed.", tag: "Heuristic" },
  { name: "Transcript Quality", desc: "LLM judge scores input quality and response quality.", tag: "LLM judge" },
  { name: "Reasoning Quality", desc: "Depth, coherence, and self-correction in agent reasoning.", tag: "LLM judge" },
  { name: "Regression", desc: "Statistical z-score detection against a baseline.", tag: "Statistical" },
];

const feed = [
  { app: "claude-code", color: "text-pink-400", border: "border-purple-500/30", event: "PreToolUse", detail: "Edit · src/db.ts", time: "12:04:21" },
  { app: "gemini-cli", color: "text-cyan-400", border: "border-cyan-500/40", event: "SessionStart", detail: "session a91f…", time: "12:04:19" },
  { app: "claude-code", color: "text-pink-400", border: "border-purple-500/30", event: "PostToolUse", detail: "Bash · npm test ✓", time: "12:04:15" },
  { app: "claude-code", color: "text-pink-400", border: "border-purple-500/30", event: "Notification", detail: "Permission requested", time: "12:04:09" },
  { app: "gemini-cli", color: "text-cyan-400", border: "border-cyan-500/40", event: "AfterTool", detail: "Read · README.md", time: "12:04:02" },
];
---

<BrandLayout theme="dark" active="tools" title="Multi-Agent Observability — Mission Control for AI Coding | Zachary Lewis" description="A real-time, open-source observability dashboard for Claude Code and Gemini CLI. Live event feed, agent tracking, transcripts, and LLM-powered evaluation.">
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-zinc-800">
    <div class="absolute inset-0 bg-transparent"></div>
    <div class="absolute -top-24 -left-24 w-96 h-96 hidden"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-flex items-center gap-2 bg-zinc-900/40 border border-zinc-800 rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-pink-400 mb-6">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          Open source · Free
        </span>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-black tracking-tight text-white leading-[1.05]">
          Mission control for your <span class="text-pink-400">AI coding sessions.</span>
        </h1>
        <p class="mt-6 text-lg md:text-xl text-zinc-300 leading-relaxed">
          A real-time observability dashboard for <strong>Claude Code</strong> and <strong>Gemini CLI</strong>.
          It captures every hook event, streams it over WebSocket, and shows your agents working — live.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href="#quick-start" class="px-7 py-3.5 rounded-xl bg-gradient-to-r from-pink-600 to-purple-600 text-white font-semibold text-center hover:opacity-90 transition-opacity">⚡ Quick start</a>
          <a href={REPO_URL} target={REPO_URL.startsWith("http") ? "_blank" : undefined} rel="noopener noreferrer" class="px-7 py-3.5 rounded-xl border border-zinc-800 text-white font-semibold text-center hover:bg-zinc-800/50 transition-colors">View on GitHub →</a>
        </div>
      </div>

      <!-- Live feed mockup -->
      <div class="rounded-2xl border border-zinc-800 bg-black/60 overflow-hidden shadow-2xl">
        <div class="flex items-center justify-between px-4 py-3 border-b border-zinc-800 bg-zinc-900/40">
          <div class="flex items-center gap-2 text-sm">
            <span class="w-2.5 h-2.5 rounded-full bg-green-400 animate-pulse"></span>
            <span class="font-mono text-zinc-300">live event feed</span>
          </div>
          <div class="flex gap-1.5">
            <span class="px-2 py-0.5 rounded-full text-[10px] font-mono border border-purple-500/30 text-pink-400">claude-code</span>
            <span class="px-2 py-0.5 rounded-full text-[10px] font-mono border border-cyan-500/40 text-cyan-400">gemini-cli</span>
          </div>
        </div>
        <div class="p-3 space-y-2 font-mono text-xs">
          {feed.map((e) => (
            <div class={`flex items-center gap-3 rounded-lg border ${e.border} bg-zinc-900/40 px-3 py-2`}>
              <span class="text-zinc-600">{e.time}</span>
              <span class={`${e.color} font-semibold`}>{e.event}</span>
              <span class="text-zinc-400 truncate">{e.detail}</span>
              <span class="ml-auto text-[10px] text-zinc-600">{e.app}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- THE PROBLEM -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16 md:py-20 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">When agents run, you fly blind.</h2>
    <p class="text-zinc-400 text-lg leading-relaxed">
      Claude Code and Gemini CLI fire lifecycle hooks the whole time they work — tool calls, session events, permission prompts.
      Normally that signal just scrolls past in a terminal and disappears. This captures it, stores it, and turns it into a live picture of what your agents are actually doing.
    </p>
  </section>

  <!-- FEATURES -->
  <section class="border-y border-zinc-800 bg-zinc-900/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <h2 class="text-3xl font-bold text-white mb-10">What you get</h2>
      <div class="grid gap-6 md:grid-cols-3">
        {features.map((f) => (
          <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-7">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-lg font-bold text-white mb-2">{f.title}</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <h2 class="text-3xl font-bold text-white mb-10">How it works</h2>
    <div class="grid gap-6 md:grid-cols-4">
      {[
        { n: "01", t: "Hooks fire", d: "Claude Code (14 events) and Gemini CLI (8 events) run lightweight Python hook scripts as they work." },
        { n: "02", t: "Events POST in", d: "Each hook sends its event to a Bun server — tagged by source_app + session_id." },
        { n: "03", t: "Stored + streamed", d: "Events land in SQLite (WAL mode) and broadcast over WebSocket in real time." },
        { n: "04", t: "You watch live", d: "A React 19 dashboard renders the feed, agent status, transcripts, insights, and evals." },
      ].map((s) => (
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6">
          <div class="text-2xl font-black text-pink-400">{s.n}</div>
          <h3 class="mt-3 text-lg font-bold text-white">{s.t}</h3>
          <p class="mt-2 text-sm text-zinc-400 leading-relaxed">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- EVALUATION -->
  <section class="border-y border-zinc-800 bg-zinc-900/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="max-w-2xl mb-10">
        <span class="text-xs font-semibold uppercase tracking-wider text-pink-400">Beyond watching</span>
        <h2 class="mt-2 text-3xl font-bold text-white">Score your agents, catch regressions</h2>
        <p class="mt-3 text-zinc-400 leading-relaxed">A pluggable evaluation system grades sessions across multiple dimensions — from a no-API-key heuristic to LLM judges and statistical regression detection.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {evaluators.map((e) => (
          <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6">
            <span class="text-[10px] font-semibold uppercase tracking-wider text-pink-400 bg-purple-500/10 border border-purple-500/30 rounded-full px-2.5 py-1">{e.tag}</span>
            <h3 class="mt-3 text-base font-bold text-white">{e.name}</h3>
            <p class="mt-1.5 text-sm text-zinc-400 leading-relaxed">{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- QUICK START -->
  <section id="quick-start" class="scroll-mt-20 max-w-4xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <h2 class="text-3xl font-bold text-white mb-3">Quick start</h2>
    <p class="text-zinc-400 mb-8">Built on Bun + SQLite (server) and React 19 + Vite + Tailwind (dashboard), with Python hook scripts run via <code class="text-pink-400 bg-black/60 px-1.5 py-0.5 rounded text-sm">uv</code>.</p>

    <div class="grid sm:grid-cols-3 gap-3 mb-8">
      {["Bun — runtime for server + client", "uv — runs the Python hooks", "just — task runner (optional)"].map((p) => (
        <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-4 text-sm text-zinc-300">{p}</div>
      ))}
    </div>

    <div class="rounded-2xl border border-zinc-800 bg-black/60 overflow-hidden">
      <div class="px-4 py-2.5 border-b border-zinc-800 bg-zinc-900/40 text-xs font-mono text-zinc-400">terminal</div>
      <pre class="p-4 text-sm font-mono text-white overflow-x-auto leading-relaxed"><span class="text-zinc-600"># 1. install server + client deps</span>
just install

<span class="text-zinc-600"># 2. start the system (server + dashboard)</span>
just start

<span class="text-zinc-600"># 3. open the dashboard, then run Claude Code / Gemini CLI</span>
<span class="text-zinc-600">#    with the hooks wired up — events stream in live.</span></pre>
    </div>
    <p class="text-sm text-zinc-500 mt-4">Hook setup for both Claude Code and Gemini CLI is documented in <code class="text-zinc-300">docs/hook-setup.md</code> in the repo.</p>
  </section>

  <!-- CTA -->
  <section class="border-t border-zinc-800 bg-zinc-900/40">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Free, open source, and yours to run.</h2>
      <p class="text-zinc-400 text-lg mb-8">Grab it on GitHub — or if you want observability built into your own agent platform, let's talk.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={REPO_URL} target={REPO_URL.startsWith("http") ? "_blank" : undefined} rel="noopener noreferrer" class="px-7 py-3.5 rounded-xl bg-gradient-to-r from-pink-600 to-purple-600 text-white font-semibold hover:opacity-90 transition-opacity">View on GitHub</a>
        <a href="/contact" class="px-7 py-3.5 rounded-xl border border-zinc-800 text-white font-semibold hover:bg-zinc-800/50 transition-colors">Work with me</a>
      </div>
      <p class="mt-8 text-sm text-zinc-500"><a href="/tools" class="hover:text-zinc-300 transition-colors">← Back to all free tools</a></p>
    </div>
  </section>
</BrandLayout>
