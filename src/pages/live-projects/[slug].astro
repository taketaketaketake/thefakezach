---
import "../../styles/global.css";
import { liveProjects, type LiveProject, type MetricSource } from "../../data/live-projects";

export async function getStaticPaths() {
  return liveProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: LiveProject;
}

const { project } = Astro.props as Props;

const statusDisplayMap: Record<string, string> = {
  "live": "Live",
  "in-progress": "In Progress",
  "paused": "Paused",
};

const statusBadgeClass: Record<string, string> = {
  "live": "bg-green-500/20 text-green-400 border-green-500/30",
  "in-progress": "bg-yellow-500/20 text-yellow-400 border-yellow-500/30",
  "paused": "bg-zinc-500/20 text-zinc-400 border-zinc-500/30",
};

// Render the source contract for a metric. Every metric carries a typed
// `source` describing how the live value will be read once wiring is added.
function sourceRef(s: MetricSource): string {
  switch (s.kind) {
    case "supabase":
      return `${s.table} · ${s.query}`;
    case "prisma":
      return `${s.model} · ${s.query}`;
    case "api":
      return `${s.endpoint} → ${s.field}`;
    case "manual":
      return s.description;
  }
}

// Format the period-over-period delta for the metric chip.
// Null pct renders as a neutral em-dash + window label; signed values are
// colored green (up) or red (down).
function formatDelta(d: { window: string; pct: number | null }): {
  text: string;
  cls: string;
} {
  const neutral = "text-zinc-400 bg-zinc-800/60 border-zinc-700";
  if (d.pct === null) {
    return { text: `— ${d.window}`, cls: neutral };
  }
  const text = `${d.pct > 0 ? "+" : ""}${d.pct.toFixed(1)}% ${d.window}`;
  if (d.pct > 0)
    return { text, cls: "text-green-400 bg-green-500/10 border-green-500/30" };
  if (d.pct < 0)
    return { text, cls: "text-red-400 bg-red-500/10 border-red-500/30" };
  return { text, cls: neutral };
}

const formatDate = (iso: string) =>
  new Date(iso + "T00:00:00").toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });

const pageTitle = `${project.title} | Live Projects`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={project.summary} />
    <meta name="theme-color" content="#ec4899" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="bg-zinc-950 text-zinc-50 font-sans min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

      <!-- Back link -->
      <a
        href="/live-projects"
        class="inline-flex items-center gap-2 text-pink-400 hover:text-pink-300 text-sm font-semibold no-underline hover:no-underline mb-8"
      >
        ← Live Projects
      </a>

      <!-- Hero -->
      <header
        class="relative grid grid-cols-1 md:grid-cols-[1fr_220px] gap-6 bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6 sm:p-8 mb-6"
      >
        <span
          class={`absolute top-4 right-4 px-3 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full border ${statusBadgeClass[project.status]}`}
        >
          {statusDisplayMap[project.status]}
        </span>

        <div class="min-w-0">
          <div class="flex items-baseline gap-3 flex-wrap mb-2 pr-24">
            <span class="text-3xl leading-none">{project.emoji}</span>
            <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-white">
              {project.title}
            </h1>
            <span class="bg-zinc-800 text-pink-400 px-3 py-1 rounded-full text-xs font-medium">
              {project.year}
            </span>
          </div>
          <p class="text-pink-400 font-medium mb-4">{project.tagline}</p>
          <p class="text-zinc-300 leading-relaxed">{project.summary}</p>
        </div>

        <div class="flex items-center justify-center order-first md:order-none">
          {project.image ? (
            <img
              src={project.image}
              alt={project.title}
              class="w-full aspect-square object-cover rounded-xl border border-zinc-800"
              style={project.imagePosition ? `object-position: ${project.imagePosition}` : undefined}
              loading="lazy"
            />
          ) : (
            <div
              class="w-full aspect-square flex items-center justify-center bg-zinc-800/40 border border-dashed border-zinc-700 rounded-xl text-7xl"
            >
              {project.emoji}
            </div>
          )}
        </div>
      </header>

      <!-- Operating model + Stack -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <section class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6">
          <h2 class="text-xs font-bold uppercase tracking-wider text-pink-400 mb-3">
            Operating Model
          </h2>
          <p class="text-zinc-300 leading-relaxed">{project.model}</p>
        </section>

        <section class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6">
          <h2 class="text-xs font-bold uppercase tracking-wider text-pink-400 mb-3">
            Stack
          </h2>
          <ul class="flex flex-wrap gap-2">
            {project.stack.map((s) => (
              <li class="px-3 py-1 text-sm bg-zinc-800 text-zinc-300 rounded-full border border-zinc-700">
                {s}
              </li>
            ))}
          </ul>
        </section>
      </div>

      <!-- Metrics -->
      <section class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6 mb-6">
        <h2 class="text-xs font-bold uppercase tracking-wider text-pink-400 mb-4">
          Metrics
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {project.metrics.map((m) => {
            const ref = sourceRef(m.source);
            const delta = formatDelta(m.delta);
            return (
              <div class="bg-zinc-950/60 border border-zinc-800 rounded-xl p-5">
                <div class="flex items-baseline justify-between mb-2 gap-3">
                  <span class="text-xs font-bold uppercase tracking-wider text-pink-400">
                    {m.label}
                  </span>
                  <span
                    class={`text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded border ${delta.cls}`}
                    title={`Change vs previous ${m.delta.window}`}
                  >
                    {delta.text}
                  </span>
                </div>
                <div class="text-3xl sm:text-4xl font-extrabold text-white leading-none mb-1">
                  {m.value}
                </div>
                {m.hint && <div class="text-xs text-zinc-500 mb-3">{m.hint}</div>}
                <div
                  class="font-mono text-xs text-zinc-300 bg-black/40 border border-zinc-800 rounded-md px-3 py-2 mb-2 break-all"
                >
                  {ref}
                </div>
                <div class="text-xs text-zinc-500 leading-relaxed">
                  {m.source.description}
                </div>
              </div>
            );
          })}
        </div>
      </section>

      <!-- Focus + Activity -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <section class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6">
          <h2 class="text-xs font-bold uppercase tracking-wider text-pink-400 mb-3">
            Current Focus
          </h2>
          <ul class="divide-y divide-zinc-800">
            {project.focus.map((f) => (
              <li class="py-3 first:pt-0 last:pb-0 text-zinc-300 flex gap-3">
                <span class="text-pink-400 font-bold leading-relaxed">›</span>
                <span class="leading-relaxed">{f}</span>
              </li>
            ))}
          </ul>
        </section>

        <section class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6">
          <h2 class="text-xs font-bold uppercase tracking-wider text-pink-400 mb-3">
            Recent Activity
          </h2>
          <ul class="divide-y divide-zinc-800">
            {project.activity.map((a) => (
              <li class="py-3 first:pt-0 last:pb-0 grid grid-cols-[100px_1fr] gap-4">
                <span class="text-pink-400 font-mono text-xs pt-0.5">{formatDate(a.date)}</span>
                <span class="text-zinc-300 leading-relaxed">{a.note}</span>
              </li>
            ))}
          </ul>
        </section>
      </div>

      <!-- Links -->
      {(project.links.live || project.links.repo || project.links.dashboard) && (
        <section class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6 mb-6">
          <h2 class="text-xs font-bold uppercase tracking-wider text-pink-400 mb-4">
            Links
          </h2>
          <div class="flex flex-wrap gap-3">
            {project.links.live && (
              <a
                href={project.links.live}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-gradient-to-r from-pink-500 to-purple-500 text-white px-4 py-2 rounded-lg font-bold text-xs uppercase tracking-wider no-underline hover:no-underline hover:scale-105 transition-transform"
              >
                Live Site →
              </a>
            )}
            {project.links.dashboard && (
              <a
                href={project.links.dashboard}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-gradient-to-r from-pink-500 to-purple-500 text-white px-4 py-2 rounded-lg font-bold text-xs uppercase tracking-wider no-underline hover:no-underline hover:scale-105 transition-transform"
              >
                Dashboard →
              </a>
            )}
            {project.links.repo && (
              <a
                href={project.links.repo}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-zinc-900 text-pink-400 border border-zinc-800 hover:border-pink-500/40 px-4 py-2 rounded-lg font-bold text-xs uppercase tracking-wider no-underline hover:no-underline transition-colors"
              >
                Source ↗
              </a>
            )}
          </div>
        </section>
      )}

      <!-- Footer -->
      <footer class="mt-6 pt-8 border-t border-zinc-800 text-center text-xs text-zinc-500">
        © {new Date().getFullYear()} Zachary Lewis
      </footer>

    </div>
  </body>
</html>
