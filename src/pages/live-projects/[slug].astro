---
import { liveProjects, type LiveProject, type MetricSource } from "../../data/live-projects";

export async function getStaticPaths() {
  return liveProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: LiveProject;
}

const { project } = Astro.props as Props;

const statusDisplayMap: Record<string, string> = {
  "live": "Live",
  "in-progress": "In Progress",
  "paused": "Paused",
};

// Render the source contract for a metric as a small developer-readable line.
// This makes the "wiring intent" visible — every metric shows where its live
// value will come from once hooked up.
function renderSource(s: MetricSource): { kindLabel: string; ref: string } {
  switch (s.kind) {
    case "supabase":
      return { kindLabel: "supabase", ref: `${s.table} · ${s.query}` };
    case "prisma":
      return { kindLabel: "prisma", ref: `${s.model} · ${s.query}` };
    case "api":
      return { kindLabel: "api", ref: `${s.endpoint} → ${s.field}` };
    case "manual":
      return { kindLabel: "manual", ref: s.description };
  }
}

const pageTitle = `${project.title} – Live Projects`;
const formatDate = (iso: string) => {
  const d = new Date(iso + "T00:00:00");
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>

    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      :root {
        --aqua: #0EF2D4;
        --chartreuse: #CEF64D;
        --amber: #FFD55A;
        --navy: #0A214B;
        --indigo: #2B1A55;
        --pink: #FF0080;
        --cyan: #00FFFF;
      }

      body {
        background: linear-gradient(180deg, var(--navy), var(--indigo));
        color: white;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
      }

      .page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 2rem 4rem;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--aqua);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        opacity: 0.85;
        transition: all 0.2s ease;
        margin-bottom: 2rem;
      }

      .back-link:hover {
        opacity: 1;
        color: var(--pink);
      }

      .hero {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: 2rem;
        padding: 2.5rem;
        background: rgba(0, 0, 0, 0.55);
        border: 2px solid var(--aqua);
        border-radius: 1rem;
        backdrop-filter: blur(10px);
        margin-bottom: 2rem;
        position: relative;
      }

      .hero-status {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        padding: 0.4rem 0.9rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .status-live { background: var(--chartreuse); color: var(--navy); }
      .status-inprogress { background: var(--amber); color: var(--navy); }
      .status-paused { background: rgba(255, 255, 255, 0.2); color: white; }

      .hero-header {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
      }

      .hero-emoji {
        font-size: 2.5rem;
        line-height: 1;
      }

      .hero-title {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 900;
        color: white;
      }

      .hero-year {
        background: var(--navy);
        color: var(--aqua);
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.85rem;
        font-weight: 600;
      }

      .hero-tagline {
        color: var(--cyan);
        font-size: 1.1rem;
        font-weight: 500;
        margin-bottom: 1.25rem;
      }

      .hero-summary {
        color: #e2e8f0;
        font-size: 1rem;
        line-height: 1.7;
      }

      .hero-image,
      .hero-emoji-fallback {
        width: 220px;
        height: 220px;
        border-radius: 1rem;
        align-self: center;
      }

      .hero-image {
        object-fit: cover;
        border: 2px solid rgba(255, 255, 255, 0.2);
      }

      .hero-emoji-fallback {
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.06);
        border: 2px dashed rgba(255, 255, 255, 0.18);
        font-size: 6rem;
      }

      .section {
        background: rgba(0, 0, 0, 0.55);
        border: 1px solid rgba(14, 242, 212, 0.25);
        border-radius: 1rem;
        padding: 2rem;
        margin-bottom: 1.5rem;
        backdrop-filter: blur(10px);
      }

      .section-title {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--aqua);
        font-weight: 700;
        margin-bottom: 1rem;
      }

      .section-body {
        color: #e2e8f0;
        font-size: 1rem;
        line-height: 1.7;
      }

      .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      }

      .metric-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }

      .metric-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(14, 242, 212, 0.25);
        border-radius: 0.75rem;
        padding: 1.25rem;
      }

      .metric-card-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.5rem;
      }

      .metric-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: var(--aqua);
        font-weight: 700;
      }

      .metric-source-kind {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: #94a3b8;
        background: rgba(255, 255, 255, 0.05);
        padding: 0.15rem 0.5rem;
        border-radius: 0.4rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
      }

      .metric-value {
        font-size: 2.25rem;
        font-weight: 900;
        color: white;
        line-height: 1;
        margin: 0.5rem 0 0.25rem;
      }

      .metric-hint {
        font-size: 0.8rem;
        color: #94a3b8;
        margin-bottom: 0.85rem;
      }

      .metric-source-ref {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
        font-size: 0.72rem;
        color: #cbd5e1;
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 0.5rem 0.6rem;
        border-radius: 0.4rem;
        word-break: break-word;
        margin-bottom: 0.4rem;
      }

      .metric-source-desc {
        font-size: 0.78rem;
        color: #94a3b8;
        line-height: 1.5;
      }

      .focus-list,
      .activity-list {
        list-style: none;
      }

      .focus-list li {
        position: relative;
        padding: 0.6rem 0 0.6rem 1.5rem;
        color: #e2e8f0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .focus-list li:last-child { border-bottom: none; }

      .focus-list li::before {
        content: "›";
        position: absolute;
        left: 0;
        color: var(--pink);
        font-weight: 700;
      }

      .activity-list li {
        display: grid;
        grid-template-columns: 110px 1fr;
        gap: 1rem;
        padding: 0.6rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        color: #e2e8f0;
        font-size: 0.95rem;
      }

      .activity-list li:last-child { border-bottom: none; }

      .activity-date {
        color: var(--aqua);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
        font-size: 0.85rem;
      }

      .stack-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .stack-tag {
        background: rgba(255, 255, 255, 0.06);
        color: var(--aqua);
        border: 1px solid var(--aqua);
        padding: 0.25rem 0.7rem;
        border-radius: 1rem;
        font-size: 0.8rem;
        font-weight: 500;
      }

      .links-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .link-button {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.6rem 1.1rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .link-primary {
        background: linear-gradient(45deg, var(--pink), var(--cyan));
        color: white;
      }

      .link-secondary {
        background: rgba(255, 255, 255, 0.06);
        color: var(--aqua);
        border: 1px solid var(--aqua);
      }

      .link-button:hover {
        transform: scale(1.04);
        box-shadow: 0 8px 20px rgba(255, 0, 128, 0.25);
      }

      @media (max-width: 768px) {
        .hero {
          grid-template-columns: 1fr;
        }

        .hero-image,
        .hero-emoji-fallback {
          width: 100%;
          height: 200px;
          font-size: 5rem;
        }

        .two-col,
        .metric-grid {
          grid-template-columns: 1fr;
        }

        .activity-list li {
          grid-template-columns: 90px 1fr;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <a href="/live-projects" class="back-link">← Live Projects</a>

      <!-- Hero -->
      <header class="hero">
        <div class={`hero-status status-${project.status.replace("-", "")}`}>
          {statusDisplayMap[project.status]}
        </div>

        <div>
          <div class="hero-header">
            <span class="hero-emoji">{project.emoji}</span>
            <h1 class="hero-title">{project.title}</h1>
            <span class="hero-year">{project.year}</span>
          </div>
          <div class="hero-tagline">{project.tagline}</div>
          <p class="hero-summary">{project.summary}</p>
        </div>

        {project.image ? (
          <img
            src={project.image}
            alt={project.title}
            class="hero-image"
            style={project.imagePosition ? `object-position: ${project.imagePosition}` : undefined}
          />
        ) : (
          <div class="hero-emoji-fallback">{project.emoji}</div>
        )}
      </header>

      <!-- Operating model + stack -->
      <div class="two-col">
        <section class="section">
          <div class="section-title">Operating Model</div>
          <div class="section-body">{project.model}</div>
        </section>

        <section class="section">
          <div class="section-title">Stack</div>
          <div class="stack-row">
            {project.stack.map((s) => <span class="stack-tag">{s}</span>)}
          </div>
        </section>
      </div>

      <!-- Metrics -->
      <section class="section">
        <div class="section-title">Metrics</div>
        <div class="metric-grid">
          {project.metrics.map((m) => {
            const src = renderSource(m.source);
            return (
              <div class="metric-card">
                <div class="metric-card-header">
                  <span class="metric-label">{m.label}</span>
                  <span class="metric-source-kind">{src.kindLabel}</span>
                </div>
                <div class="metric-value">{m.value}</div>
                {m.hint && <div class="metric-hint">{m.hint}</div>}
                <div class="metric-source-ref">{src.ref}</div>
                <div class="metric-source-desc">{m.source.description}</div>
              </div>
            );
          })}
        </div>
      </section>

      <!-- Focus + activity -->
      <div class="two-col">
        <section class="section">
          <div class="section-title">Current Focus</div>
          <ul class="focus-list">
            {project.focus.map((f) => <li>{f}</li>)}
          </ul>
        </section>

        <section class="section">
          <div class="section-title">Recent Activity</div>
          <ul class="activity-list">
            {project.activity.map((a) => (
              <li>
                <span class="activity-date">{formatDate(a.date)}</span>
                <span>{a.note}</span>
              </li>
            ))}
          </ul>
        </section>
      </div>

      <!-- Links -->
      {(project.links.live || project.links.repo || project.links.dashboard) && (
        <section class="section">
          <div class="section-title">Links</div>
          <div class="links-row">
            {project.links.live && (
              <a href={project.links.live} target="_blank" rel="noopener noreferrer" class="link-button link-primary">
                Live Site →
              </a>
            )}
            {project.links.dashboard && (
              <a href={project.links.dashboard} target="_blank" rel="noopener noreferrer" class="link-button link-primary">
                Dashboard →
              </a>
            )}
            {project.links.repo && (
              <a href={project.links.repo} target="_blank" rel="noopener noreferrer" class="link-button link-secondary">
                Source ↗
              </a>
            )}
          </div>
        </section>
      )}
    </div>
  </body>
</html>
