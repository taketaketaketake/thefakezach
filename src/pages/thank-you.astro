---
import BrandLayout from "../layouts/BrandLayout.astro";
---

<BrandLayout active="" title="Thank You | Zachary Lewis" description="Thanks for reaching out.">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 py-28 md:py-36 text-center">
    <div class="text-5xl mb-6">🚀</div>
    <h1 class="text-4xl md:text-5xl font-black text-ink mb-4">You're in.</h1>
    <p class="text-lg text-ink/80 mb-8">
      Thanks for reaching out. I read everything personally and respond within 48 hours.
      Keep an eye on your inbox.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/" class="px-6 py-3.5 rounded-xl bg-accent text-white border border-ink font-semibold hover:opacity-90 transition-opacity">
        Back to home
      </a>
      <a href="/services" class="px-6 py-3.5 rounded-xl border border-ink text-ink font-semibold hover:bg-paper2 transition-colors">
        See services
      </a>
    </div>
  </section>
</BrandLayout>
