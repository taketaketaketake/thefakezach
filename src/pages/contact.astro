---
import BrandLayout from "../layouts/BrandLayout.astro";
---

<BrandLayout active="contact" title="Contact | Zachary Lewis" description="Get in touch with Zachary Lewis about AI builds, automation, or team workshops.">
  <section class="relative overflow-hidden border-b border-ink">
    <div class="absolute inset-0 bg-transparent"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-20 text-center">
      <span class="text-xs font-semibold uppercase tracking-wider text-accent">Contact</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-black text-ink leading-tight">Let's talk.</h1>
      <p class="mt-4 text-lg text-ink/80">
        Tell me what you're trying to build or automate. I respond within 48 hours.
      </p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/thank-you"
      class="space-y-5 rounded-2xl border border-ink bg-white p-6 md:p-8"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden">
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>

      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label for="name" class="block text-sm font-medium text-ink/80 mb-2">Name</label>
          <input id="name" type="text" name="name" required class="w-full px-4 py-3 rounded-xl bg-white border border-ink text-ink placeholder-ink/40 focus:outline-none focus:border-accent" placeholder="Your name" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-ink/80 mb-2">Email</label>
          <input id="email" type="email" name="email" required class="w-full px-4 py-3 rounded-xl bg-white border border-ink text-ink placeholder-ink/40 focus:outline-none focus:border-accent" placeholder="you@email.com" />
        </div>
      </div>

      <div>
        <label for="topic" class="block text-sm font-medium text-ink/80 mb-2">What's this about?</label>
        <select id="topic" name="topic" class="w-full px-4 py-3 rounded-xl bg-white border border-ink text-ink focus:outline-none focus:border-accent">
          <option>AI strategy &amp; build</option>
          <option>Team workshop / training</option>
          <option>Something else</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-ink/80 mb-2">Message</label>
        <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-xl bg-white border border-ink text-ink placeholder-ink/40 focus:outline-none focus:border-accent" placeholder="Tell me what you're working on..."></textarea>
      </div>

      <button type="submit" class="w-full px-6 py-3.5 rounded-xl bg-accent text-white border border-ink font-semibold hover:opacity-90 transition-opacity">
        Send message
      </button>

      <p class="text-center text-sm text-ink/50">
        Prefer email? <a href="mailto:zach@takedetroit.com" class="text-accent hover:underline">zach@takedetroit.com</a>
      </p>
    </form>
  </section>
</BrandLayout>
