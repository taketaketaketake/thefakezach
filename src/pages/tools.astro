---
import BrandLayout from "../layouts/BrandLayout.astro";
import { tools } from "../data/showcase";

const featured = tools.find((t) => t.featured);
const rest = tools.filter((t) => !t.featured);
---

<BrandLayout active="tools" title="Free Tools | Zachary Lewis" description="Free, no-signup tools and open-source utilities for working with AI — including the USER.md generator.">
  <!-- Header -->
  <section class="relative overflow-hidden border-b border-ink">
    <div class="absolute inset-0 bg-transparent"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-24">
      <span class="text-xs font-semibold uppercase tracking-wider text-accent">Free Tools</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-black text-ink leading-tight max-w-3xl">
        Free tools to work smarter with AI.
      </h1>
      <p class="mt-5 text-lg text-ink/80 max-w-2xl leading-relaxed">
        No signup, no catch. I build these because they're useful — and because the best way to show you what I do is to let you use it.
      </p>
    </div>
  </section>

  <!-- Featured tool -->
  {featured && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-16">
      <a href={featured.href} class="group block no-underline rounded-3xl border border-ink bg-accent/10 p-8 md:p-12 hover:border-accent transition-all">
        <div class="flex flex-wrap items-center gap-3 mb-3">
          <span class="text-xs font-semibold uppercase tracking-wider text-accent bg-accent/10 border border-accent rounded-full px-3 py-1">⭐ Featured · {featured.status}</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-black text-ink group-hover:text-accent transition-colors">{featured.title}</h2>
        <p class="mt-2 text-accent font-semibold text-lg">{featured.tagline}</p>
        <p class="mt-4 text-ink/80 leading-relaxed max-w-2xl">{featured.description}</p>
        <span class="mt-6 inline-block px-6 py-3 rounded-xl bg-accent text-white border border-ink font-semibold group-hover:opacity-90 transition-opacity">{featured.cta} →</span>
      </a>
    </section>
  )}

  <!-- Other tools -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <h2 class="text-2xl font-bold text-ink mb-8">More free &amp; open-source tools</h2>
    <div class="grid gap-6 md:grid-cols-3">
      {rest.map((t) => (
        <div class="flex flex-col rounded-2xl border border-ink bg-white p-7 hover:border-accent transition-colors">
          <span class="text-xs font-semibold uppercase tracking-wider text-ink/50 mb-3">{t.status}</span>
          <h3 class="text-xl font-bold text-ink">{t.title}</h3>
          <p class="text-accent text-sm font-medium mt-1">{t.tagline}</p>
          <p class="text-ink/60 text-sm leading-relaxed mt-3 flex-1">{t.description}</p>
          {t.install && (
            <code class="mt-4 block text-xs text-cyan-300 bg-ink border border-ink rounded-lg px-3 py-2 font-mono overflow-x-auto">{t.install}</code>
          )}
          {t.href && (
            <a
              href={t.href}
              target={t.href.startsWith("http") ? "_blank" : undefined}
              rel={t.href.startsWith("http") ? "noopener noreferrer" : undefined}
              class="mt-5 inline-block text-sm font-semibold text-accent hover:translate-x-1 transition-transform"
            >
              {t.cta} →
            </a>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-ink bg-paper2">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-ink mb-3">Need something custom?</h2>
      <p class="text-ink/60 text-lg mb-8">If a free tool gets you 80% there, I can build the other 20% for your business.</p>
      <a href="/contact" class="inline-block px-7 py-3.5 rounded-xl bg-accent text-white border border-ink font-semibold hover:opacity-90 transition-opacity">Work with me</a>
    </div>
  </section>
</BrandLayout>
