---
import "../styles/global.css";

const pageTitle = "Resume | Zachary Lewis";

const skills = {
  languages: ["TypeScript", "JavaScript", "Python", "SQL"],
  frontend: ["React", "React Native", "Astro", "Expo", "Tailwind CSS", "Vite", "Three.js"],
  backend: ["Node.js", "Bun", "Express", "FastAPI", "Prisma", "Socket.io", "BullMQ", "Microservices", "REST APIs"],
  "ai & agents": ["Telnyx AI", "Deepgram", "Gemini", "LLM Evaluation", "Multi-Agent Systems", "A2A Protocol", "LangChain", "Claude SDK"],
  databases: ["PostgreSQL", "SQLite", "Redis", "Supabase"],
  "auth & payments": ["Stripe", "Better Auth", "JWT", "Magic Links", "OAuth"],
  "real-time": ["WebSocket", "Socket.io", "SSE", "Message Queues"],
  "cloud & infra": ["AWS", "GCP", "Docker", "Railway", "Netlify", "GitHub Actions", "Sentry", "CI/CD"],
  integrations: ["Twilio", "Resend", "Shopify", "Mapbox", "Google Places"],
  video: ["Live Streaming", "Multi-Camera Production", "OBS", "vMix", "Remotion"]
};

const projects = [
  {
    title: "AgentlandOS",
    subtitle: "AI Agent Operating System",
    tech: ["React", "Python", "Vite", "Better Auth", "Sentry"],
    website: "agentlandos.com",
    highlights: [
      "Microservices architecture with 15+ service modules across orchestration, planning, and execution",
      "Agent routing, tool invocation, and human-in-the-loop workflows",
      "Telemetry, billing, and multi-tenant auth with observability layers"
    ]
  },
  {
    title: "Voice AI Systems",
    subtitle: "Production Voice Agents",
    tech: ["Node.js", "Express", "Telnyx", "Python", "SQLite", "Supabase"],
    phone: "(833) FIX-IT-NOW",
    phoneLink: "tel:+18333498669",
    highlights: [
      "Deployed production voice AI agents handling live customer calls with sub-500ms response latency",
      "Built real-time call monitoring dashboard with conversation memory and context persistence",
      "Architected for 1000+ concurrent calls with graceful failover"
    ]
  },
  {
    title: "AgentLand Observability",
    subtitle: "Multi-Agent Monitoring Dashboard",
    tech: ["Bun", "SQLite", "React", "WebSocket", "Python"],
    website: "github.com/thefakezach",
    highlights: [
      "Real-time observability for Claude Code and Gemini CLI agent sessions",
      "Live event streaming with agent tracking, transcript viewing, and session replay",
      "LLM-powered evaluation system for scoring agent quality across runs"
    ]
  },
  {
    title: "TraceTrack",
    subtitle: "GitHub for AI Workflows",
    tech: ["Node.js", "PostgreSQL", "Redis", "WebSocket", "React"],
    website: "github.com/taketaketaketake/Trace-Track",
    highlights: [
      "Trace sharing, forking, and diffing for AI coding sessions across teams",
      "Version-controlled prompt pipelines with automated eval suites",
      "Ingestion from Langfuse, LangSmith, OpenTelemetry, and direct API"
    ]
  },
  {
    title: "A2A Telephony Protocol",
    subtitle: "Open Standard for Agent Phone Calls",
    tech: ["Python", "FastAPI", "A2A Protocol"],
    website: "github.com/taketaketaketake/telephony-protocol",
    highlights: [
      "Authored open standard extending Google's A2A protocol with telephony capabilities",
      "Reference server with conformant JSON-RPC implementation and stub carrier handlers",
      "Single operation design — any A2A-compliant agent can make phone calls and send texts"
    ]
  },
  {
    title: "On The Floor",
    subtitle: "Patient Care Experience Platform",
    tech: ["React Native", "Expo", "Express", "Prisma", "PostgreSQL", "Socket.io"],
    website: "onthefloor.app",
    highlights: [
      "Full-stack platform: React Native mobile app + Express API + PostgreSQL",
      "Real-time chat rooms with Socket.io for in-hospital patient expression",
      "Magic Link + OAuth auth, structured care reviews with scored signals"
    ]
  },
  {
    title: "SeatBites",
    subtitle: "SMS-First Food Ordering Platform",
    tech: ["Express", "Prisma", "PostgreSQL", "Redis", "Stripe", "Twilio"],
    website: "seatbites.com/about",
    highlights: [
      "Multi-tenant vendor system with smart dispatch across locations",
      "Complete 9-state order machine with BullMQ job processing",
      "Stripe integration with idempotent webhooks and retry logic"
    ]
  },
  {
    title: "Overflow",
    subtitle: "PPV Livestream Platform",
    tech: ["Astro", "Tailwind CSS", "Stripe", "JWT", "Playwright"],
    website: "watchoverflow.com",
    highlights: [
      "Built full-stack PPV platform for exclusive live events and performances",
      "Integrated payment processing and live video infrastructure",
      "E2E test coverage with Playwright and Vitest"
    ]
  },
  {
    title: "Fix My Furnace",
    subtitle: "HVAC Lead Generation Platform",
    tech: ["Astro", "Supabase", "Tailwind CSS"],
    website: "fixmyfurnacemi.com",
    highlights: [
      "Smart lead capture with phone validation and address autocomplete",
      "Contractor application portal with admin moderation",
      "Real pricing transparency system from actual service contracts"
    ]
  },
  {
    title: "Bags of Laundry",
    subtitle: "Laundry Pickup & Delivery Platform",
    tech: ["Astro", "Prisma", "PostgreSQL", "Redis", "Stripe"],
    website: "bagsoflaundry.com",
    highlights: [
      "Guest ordering with secure access tokens",
      "Service zone capacity management and scheduling",
      "Magic link auth with Stripe subscription billing"
    ]
  },
  {
    title: "Detroit Small Business Map",
    subtitle: "Self-Enriching Business Directory",
    tech: ["Hono", "Prisma", "PostgreSQL", "Redis", "Gemini AI", "Mapbox", "Astro", "React"],
    website: "github.com/thefakezach",
    highlights: [
      "Automated data enrichment pipeline using SERP, Google Places, Geoapify, and Gemini AI",
      "Quality-gated promotion system from staging to production listings",
      "Neighborhood-based discovery with Mapbox interactive maps and S3 image storage"
    ]
  },
  {
    title: "Penalty Box",
    subtitle: "E-Commerce for Darren McCarty",
    tech: ["Astro", "React", "Shopify API", "Nanostores"],
    website: "github.com/thefakezach",
    highlights: [
      "Shopify storefront integration for 4x Stanley Cup champion",
      "Event booking system with product catalog",
      "Reactive state management with Nanostores"
    ]
  }
];

const experience = [
  {
    role: "Agentic Engineer",
    company: "thefakezach.com",
    website: "thefakezach.com",
    period: "2024 - Present",
    highlights: [
      "Shipped 9+ production products: voice AI agents, multi-agent platforms, real-time systems, and mobile apps",
      "Designed agentic architectures with orchestration, tool invocation, and observability layers",
      "Authored open telephony standard for the A2A protocol; built AI workflow tracing and eval platform"
    ]
  },
  {
    role: "Founder & Creative Director",
    company: "Take Detroit / Take Media",
    website: "instagram.com/take.detroit",
    period: "2015 - Present",
    highlights: [
      "Built online brand to 100,000+ followers across social platforms",
      "Generated 25+ million video views through original content",
      "Produce video content, livestreams, and digital marketing for clients across industries",
      "Established Detroit's go-to city guide and lifestyle brand"
    ]
  },
  {
    role: "Short Term Property Manager",
    company: "Airbnb",
    period: "2024",
    highlights: [
      "Managed portfolio of residential and commercial properties",
      "Utilized Salesforce for property tracking and compliance",
      "Coordinated maintenance teams and contractors"
    ]
  }
];

const zachary = {
  name: "Zachary Lewis",
  username: "thefakezach",
  avatarPhoto: "/profile-photo.jpg",
  title: "Agentic AI Engineer",
  location: "Detroit, MI"
};

const stats = [
  { value: "100K+", label: "Followers" },
  { value: "25M+", label: "Video Views" },
  { value: "9+", label: "AI Projects" },
  { value: "9+", label: "Products Shipped" }
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content="Zachary Lewis - Agentic AI Engineer based in Detroit, MI. Building production AI agents, multi-agent platforms, and cloud-native systems." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="bg-zinc-950 text-zinc-50 font-sans min-h-screen flex flex-col">

    <!-- Hero Header -->
    <header class="relative overflow-hidden">
      <!-- Gradient Banner -->
      <div class="h-48 bg-gradient-to-br from-pink-600 via-purple-600 to-indigo-700"></div>

      <!-- Profile Card -->
      <div class="relative -mt-20 px-4 sm:px-6 max-w-5xl mx-auto">
        <div class="bg-zinc-900/80 backdrop-blur-sm rounded-2xl p-6 shadow-2xl border border-zinc-800">
          <div class="flex flex-col sm:flex-row items-center sm:items-end gap-5">
            <!-- Avatar -->
            <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-full bg-zinc-800 border-4 border-zinc-950 shadow-xl flex-shrink-0 overflow-hidden">
              <img
                src={zachary.avatarPhoto}
                alt={`${zachary.name} profile photo`}
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>

            <!-- Name & Info -->
            <div class="flex-1 text-center sm:text-left">
              <h1 class="text-2xl sm:text-3xl font-bold text-white">{zachary.name}</h1>
              <p class="text-pink-400 text-lg font-medium">{zachary.title}</p>
              <p class="text-sm text-zinc-400 mt-1">{zachary.location}</p>
            </div>

                      </div>

          <!-- Stats Row - hidden on mobile -->
          <div class="mt-6 pt-4 border-t border-zinc-800 hidden sm:grid grid-cols-4 gap-4">
            {stats.map((stat) => (
              <div class="text-center">
                <p class="text-2xl font-bold text-white">{stat.value}</p>
                <p class="text-xs text-zinc-500 uppercase tracking-wide">{stat.label}</p>
              </div>
            ))}
          </div>

          <!-- Contact Row - icons only on mobile, full text on desktop -->
          <div class="mt-4 pt-4 border-t border-zinc-800 flex justify-center sm:justify-start gap-6 text-zinc-400">
            <a href="mailto:Zach@TakeDetroit.com" class="flex items-center gap-2 hover:text-pink-400 transition-colors">
              <span>📧</span>
              <span class="hidden sm:inline text-sm">Zach@TakeDetroit.com</span>
            </a>
            <a href="https://thefakezach.com" class="flex items-center gap-2 hover:text-pink-400 transition-colors">
              <span>🌐</span>
              <span class="hidden sm:inline text-sm">thefakezach.com</span>
            </a>
            <a href="https://github.com/taketaketaketake" class="flex items-center gap-2 hover:text-pink-400 transition-colors">
              <span>💻</span>
              <span class="hidden sm:inline text-sm">GitHub</span>
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Navigation -->
    <nav class="sticky top-0 z-10 bg-zinc-950/95 backdrop-blur-sm border-b border-zinc-800">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="flex justify-center gap-1">
          <a href="/" class="px-6 py-4 text-sm font-medium text-zinc-400 hover:text-white transition-colors">
            Home
          </a>
          <span class="px-6 py-4 text-sm font-medium text-white relative">
            Resume
            <span class="absolute bottom-0 left-0 right-0 h-0.5 bg-pink-500"></span>
          </span>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-5xl mx-auto px-4 sm:px-6 py-10 flex-1">

      <!-- Summary -->
      <section class="mb-10">
        <div class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6">
          <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
            <span class="text-pink-400">About</span>
          </h2>
          <p class="text-zinc-300 text-base leading-relaxed">
            Agentic AI engineer who ships production systems. Background in video production and brand building (100K+ followers, 25M+ views) before going all-in on AI in 2024. Since then I've shipped voice AI agents handling real phone calls, built multi-agent observability and tracing platforms, authored an open telephony standard for the A2A protocol, and delivered 9+ full-stack products. I build fast, deploy to production, and communicate clearly with technical and non-technical stakeholders.
          </p>
        </div>
      </section>

      <!-- Skills -->
      <section class="mb-10">
        <div class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <span class="text-pink-400">Skills</span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {Object.entries(skills).map(([category, items]) => (
              <div class="bg-zinc-800/50 rounded-xl p-4 border border-zinc-700/50">
                <h3 class="text-xs font-semibold text-pink-400 uppercase tracking-wider mb-3">
                  {category}
                </h3>
                <div class="flex flex-wrap gap-1.5">
                  {items.map((skill) => (
                    <span class="bg-zinc-700/50 text-zinc-300 px-2 py-1 rounded text-xs">
                      {skill}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Software Projects -->
      <section class="mb-10">
        <div class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <span class="text-pink-400">Software Projects</span>
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {projects.map((project) => (
              <div class="bg-zinc-800/50 rounded-xl p-5 border border-zinc-700/50 hover:border-pink-500/30 transition-colors">
                {project.website ? (
                  <a href={`https://${project.website}`} target="_blank" rel="noopener noreferrer" class="text-lg font-semibold text-white hover:text-pink-400 transition-colors">
                    {project.title} ↗
                  </a>
                ) : (
                  <span class="text-lg font-semibold text-white">{project.title}</span>
                )}
                <p class={`text-sm text-pink-400 mt-1 ${project.phone ? 'mb-1' : 'mb-3'}`}>{project.subtitle}</p>
                {project.phone && (
                  <div class="mb-3 text-xs">
                    <a href={project.phoneLink} class="text-zinc-400 hover:text-pink-400 transition-colors">
                      📞 {project.phone}
                    </a>
                  </div>
                )}
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {project.tech.map((tech) => (
                    <span class="bg-pink-500/10 text-pink-400 px-2 py-0.5 rounded text-xs border border-pink-500/20">
                      {tech}
                    </span>
                  ))}
                </div>
                <ul class="space-y-1.5">
                  {project.highlights.map((highlight) => (
                    <li class="text-sm text-zinc-400 flex items-start gap-2">
                      <span class="text-pink-400 mt-1">›</span>
                      {highlight}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Experience -->
      <section class="mb-10">
        <div class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <span class="text-pink-400">Experience</span>
          </h2>
          <div class="space-y-6">
            {experience.map((job) => (
              <div class="relative pl-6 border-l-2 border-zinc-700">
                <div class="absolute -left-[9px] top-0 w-4 h-4 bg-pink-500 rounded-full border-4 border-zinc-900"></div>
                <div class="flex flex-wrap items-baseline gap-2 mb-1">
                  <h3 class="text-lg font-semibold text-white">{job.role}</h3>
                  <span class="text-sm text-zinc-500">•</span>
                  <span class="text-sm text-pink-400">{job.company}</span>
                  {job.website && (
                    <a href={`https://${job.website}`} class="text-xs text-zinc-500 hover:text-pink-400 transition-colors">
                      ({job.website})
                    </a>
                  )}
                </div>
                <p class="text-sm text-zinc-500 mb-3">{job.period}</p>
                <ul class="space-y-1.5">
                  {job.highlights.map((highlight) => (
                    <li class="text-sm text-zinc-400 flex items-start gap-2">
                      <span class="text-zinc-600 mt-1">–</span>
                      {highlight}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Education -->
      <section class="mb-10">
        <div class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6">
          <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
            <span class="text-pink-400">Education</span>
          </h2>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-zinc-800 rounded-full flex items-center justify-center text-2xl">
              🎓
            </div>
            <div>
              <p class="text-white font-medium">Bachelor of Science, Psychology</p>
              <p class="text-sm text-zinc-400">Kutztown University of Pennsylvania</p>
              <p class="text-sm text-zinc-500">2008</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Download Button -->
      <div class="text-center">
        <button
          onclick="window.print()"
          class="inline-flex items-center gap-2 bg-pink-500 hover:bg-pink-600 text-white font-semibold px-6 py-3 rounded-full transition-colors"
        >
          <span>📄</span>
          Download Resume
        </button>
      </div>

    </main>

    <!-- Footer -->
    <footer class="mt-auto border-t border-zinc-800 py-8 text-center text-xs text-zinc-500">
      <p>© {new Date().getFullYear()} {zachary.name}. All Rights Reserved.</p>
    </footer>

    <style>
      @media print {
        body {
          background: white;
          color: black;
        }

        .bg-zinc-950 {
          background: white;
        }

        .bg-zinc-900\/50,
        .bg-zinc-800\/50 {
          background: #f5f5f5;
          border-color: #ddd;
        }

        .text-white,
        .text-zinc-300,
        .text-zinc-400 {
          color: #333;
        }

        .text-pink-400 {
          color: #db2777;
        }

        nav,
        button,
        footer {
          display: none;
        }

        .h-48 {
          height: 60px;
        }
      }
    </style>
  </body>
</html>
