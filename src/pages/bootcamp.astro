---
import BrandLayout from "../layouts/BrandLayout.astro";

const modules = [
  {
    n: "01",
    title: "Think with AI",
    desc: "The mental models your whole team needs — what AI is genuinely great at, where it breaks, and how to direct it instead of fighting it.",
  },
  {
    n: "02",
    title: "Set your context",
    desc: "Build a team USER.md and a shared prompt library so AI actually understands your business — plus the exact tool stack we'll use.",
  },
  {
    n: "03",
    title: "Build live",
    desc: "Hands-on: each person goes from idea to a working automation or agent in the room. No slides — real building.",
  },
  {
    n: "04",
    title: "Operate with AgentlandOS",
    desc: "Deploy AI agents onto real workflows — customer inquiries, follow-ups, reporting. Not chatbots: systems that operate and report back.",
  },
  {
    n: "05",
    title: "Blueprint: a real system",
    desc: "Walk through how Fake Money is built end-to-end — agent-based signals, a deterministic risk pipeline, guardrails — as a template for ambitious builds.",
  },
];

const leaveWith = [
  "Working systems your team built that day",
  "A custom AI roadmap for your business",
  "Your team USER.md + a prompt & template kit",
  "The full session recording",
  "A 2-week follow-up to keep momentum",
];

const formats = [
  {
    tag: "Most popular",
    title: "Full day",
    meta: "~6 hours · one team",
    desc: "The flagship. Your team moves from AI-curious to shipping working systems in a single, intensive day.",
    best: "Best for getting a team building fast.",
  },
  {
    tag: null,
    title: "Multi-day",
    meta: "2–3 days · tailored",
    desc: "Deeper builds across multiple workflows, with agents deployed and a rollout plan customized to your org.",
    best: "Best for an ambitious, company-wide AI rollout.",
  },
];

const faqs = [
  { q: "Does my team need to be technical?", a: "No. The bootcamp is built for non-technical teams — ops, marketing, product, leadership. If you can use the tools you use today, you can build with AI by the end." },
  { q: "In person or remote?", a: "Both. In person in Detroit, or fully remote for distributed teams. We'll pick what fits your team." },
  { q: "How big can the team be?", a: "It's hands-on, so smaller cohorts work best. Larger groups are possible — we'll scope it on the pre-bootcamp call." },
  { q: "What do we walk away with?", a: "Real, working systems your team built — plus a roadmap, your USER.md + prompt kit, the recording, and a follow-up. Not theory." },
  { q: "How do we book?", a: "Send a few details and dates through the contact page. We start with a short call to tailor the day to your business." },
];
---

<BrandLayout active="bootcamp" title="Build-With-AI Bootcamp | Zachary Lewis" description="A hands-on corporate bootcamp where your team goes from AI-curious to building and operating real AI systems — in a day. Full-day and multi-day formats.">
  <!-- HERO -->
  <section class="border-b border-ink">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <span class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-accent mb-6">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        Corporate Bootcamp · Detroit / Remote
      </span>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-black uppercase tracking-tight text-ink leading-[1.05] max-w-3xl">
        Build-With-AI <span class="text-accent">Bootcamp.</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-ink/80 leading-relaxed max-w-2xl">
        Spend a day with me and your team leaves <em>building</em> — not nodding along to slides. We go from
        AI-curious to shipping real, working systems your business can actually use.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href="/contact" class="px-6 py-3.5 bg-accent text-white border border-ink font-bold text-center hover:shadow-lg transition-all">Request a date</a>
        <a href="#agenda" class="px-6 py-3.5 border border-ink text-ink font-bold text-center hover:bg-paper2 transition-colors">See the agenda</a>
      </div>
    </div>
  </section>

  <!-- WHAT IT IS / WHO -->
  <section class="border-b border-ink bg-paper2">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-20 grid md:grid-cols-2 gap-10">
      <div>
        <h2 class="font-mono text-[11px] uppercase tracking-widest text-ink/50 mb-3">// What it is</h2>
        <p class="text-ink/80 text-lg leading-relaxed">
          A hands-on bootcamp that takes your team from talking about AI to operating with it. We start with a
          pre-bootcamp call to tailor the day to your business, then spend it building — together, on your real work.
        </p>
      </div>
      <div>
        <h2 class="font-mono text-[11px] uppercase tracking-widest text-ink/50 mb-3">// Who it's for</h2>
        <p class="text-ink/80 text-lg leading-relaxed">
          Corporate teams who want practical AI skills, not hype — operations, marketing, product, and leadership.
          No engineering background required.
        </p>
      </div>
    </div>
  </section>

  <!-- AGENDA -->
  <section id="agenda" class="scroll-mt-20 max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <h2 class="text-3xl md:text-4xl font-bold text-ink mb-3">The day, module by module</h2>
    <p class="text-ink/60 mb-10 max-w-2xl">Five modules that build on each other — by the end, your team has shipped, not just learned.</p>
    <div class="grid gap-6 md:grid-cols-2">
      {modules.map((m) => (
        <div class="rounded-2xl border border-ink bg-white p-7">
          <div class="text-2xl font-black text-accent font-mono">{m.n}</div>
          <h3 class="mt-3 text-xl font-bold text-ink">{m.title}</h3>
          <p class="mt-2 text-ink/60 leading-relaxed">{m.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- LEAVE WITH -->
  <section class="border-y border-ink bg-paper2">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16 md:py-20">
      <h2 class="text-3xl font-bold text-ink mb-8">What your team leaves with</h2>
      <ul class="space-y-3">
        {leaveWith.map((item) => (
          <li class="flex gap-3 text-ink/80 text-lg"><span class="text-accent font-bold">✓</span><span>{item}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FORMATS -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <h2 class="text-3xl font-bold text-ink mb-10">Formats</h2>
    <div class="grid gap-6 md:grid-cols-2">
      {formats.map((f) => (
        <div class="rounded-2xl border border-ink bg-white p-8 flex flex-col">
          {f.tag && (
            <span class="self-start mb-3 font-mono text-[11px] uppercase tracking-wider text-accent bg-accent/10 border border-accent rounded-full px-3 py-1">{f.tag}</span>
          )}
          <h3 class="text-2xl font-bold text-ink">{f.title}</h3>
          <p class="mt-1 font-mono text-sm text-ink/60">{f.meta}</p>
          <p class="mt-4 text-ink/70 leading-relaxed flex-1">{f.desc}</p>
          <p class="mt-4 text-sm font-medium text-ink">{f.best}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-y border-ink bg-paper2">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <h2 class="text-3xl font-bold text-ink mb-8">Questions</h2>
      <div class="divide-y divide-ink/15">
        {faqs.map((f) => (
          <div class="py-5">
            <h3 class="font-bold text-ink">{f.q}</h3>
            <p class="mt-2 text-ink/70 leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-24 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-ink mb-4">Bring AI to your team.</h2>
    <p class="text-ink/60 text-lg mb-8">Tell me about your team and the dates you're considering — we'll start with a short call to tailor the day.</p>
    <a href="/contact" class="inline-block px-7 py-3.5 rounded-xl bg-accent text-white border border-ink font-semibold hover:opacity-90 transition-opacity">Request a date</a>
  </section>
</BrandLayout>
