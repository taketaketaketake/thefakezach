---
import "../styles/global.css";
import { liveProjects } from "../data/live-projects";

const statusDisplayMap: Record<string, string> = {
  "live": "Live",
  "in-progress": "In Progress",
  "paused": "Paused",
};

const statusBadgeClass: Record<string, string> = {
  "live": "bg-green-500/20 text-green-400 border-green-500/30",
  "in-progress": "bg-yellow-500/20 text-yellow-400 border-yellow-500/30",
  "paused": "bg-zinc-500/20 text-zinc-400 border-zinc-500/30",
};

const pageTitle = "Live Projects | thefakezach";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content="Real businesses I'm operating, in real time. Live metrics, current focus, and recent activity." />
    <meta name="theme-color" content="#ec4899" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="bg-zinc-950 text-zinc-50 font-sans min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

      <!-- Back link -->
      <a
        href="/"
        class="inline-flex items-center gap-2 text-pink-400 hover:text-pink-300 text-sm font-semibold no-underline hover:no-underline mb-8"
      >
        ← Home
      </a>

      <!-- Hero card -->
      <header
        class="bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-8 sm:p-10 mb-8 text-center"
      >
        <h1
          class="text-4xl sm:text-5xl md:text-6xl font-extrabold mb-3 bg-gradient-to-r from-pink-400 via-purple-400 to-indigo-400 bg-clip-text text-transparent"
        >
          Live Projects
        </h1>
        <p class="text-pink-400 text-lg sm:text-xl font-medium mb-4">
          Businesses I'm running, in real time
        </p>
        <p class="text-zinc-400 max-w-2xl mx-auto">
          Each card is a real operating business. Metrics here are placeholders today — the data shape underneath each one declares where the live value will be read from once wired up.
        </p>
      </header>

      <!-- Business grid -->
      <div class="flex flex-col gap-6">
        {liveProjects.map((p) => (
          <a
            href={`/live-projects/${p.slug}`}
            class="group relative grid grid-cols-1 md:grid-cols-[1fr_240px] gap-6 bg-zinc-900/50 backdrop-blur border border-zinc-800 rounded-2xl p-6 sm:p-7 text-zinc-50 no-underline hover:no-underline hover:border-pink-500/40 transition-all duration-300"
          >
            <!-- Status badge -->
            <span
              class={`absolute top-4 right-4 px-3 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full border ${statusBadgeClass[p.status]}`}
            >
              {statusDisplayMap[p.status]}
            </span>

            <!-- Content column -->
            <div class="min-w-0">
              <div class="flex items-baseline gap-3 flex-wrap mb-2 pr-24">
                <span class="text-3xl leading-none">{p.emoji}</span>
                <h2 class="text-2xl font-bold text-white">{p.title}</h2>
                <span class="bg-zinc-800 text-pink-400 px-3 py-1 rounded-full text-xs font-medium">
                  {p.year}
                </span>
              </div>

              <p class="text-pink-400 text-sm font-medium mb-4">{p.tagline}</p>

              <p class="text-zinc-300 leading-relaxed mb-5">{p.summary}</p>

              <!-- Metric row -->
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
                {p.metrics.slice(0, 4).map((m) => (
                  <div class="bg-zinc-950/60 border border-zinc-800 rounded-lg p-3">
                    <div class="text-[10px] uppercase tracking-wider text-pink-400 font-semibold mb-1 truncate">
                      {m.label}
                    </div>
                    <div class="text-2xl font-extrabold text-white leading-none mb-1">
                      {m.value}
                    </div>
                    {m.hint && <div class="text-[10px] text-zinc-500">{m.hint}</div>}
                  </div>
                ))}
              </div>

              <!-- CTA -->
              <span
                class="inline-flex items-center gap-2 bg-gradient-to-r from-pink-500 to-purple-500 text-white px-4 py-2 rounded-lg font-bold text-xs uppercase tracking-wider transition-transform group-hover:scale-105"
              >
                Open Detail →
              </span>
            </div>

            <!-- Image / emoji fallback column -->
            <div class="flex items-center justify-center order-first md:order-none">
              {p.image ? (
                <img
                  src={p.image}
                  alt={p.title}
                  class="w-full aspect-square object-cover rounded-xl border border-zinc-800"
                  style={p.imagePosition ? `object-position: ${p.imagePosition}` : undefined}
                  loading="lazy"
                />
              ) : (
                <div
                  class="w-full aspect-square flex items-center justify-center bg-zinc-800/40 border border-dashed border-zinc-700 rounded-xl text-7xl"
                >
                  {p.emoji}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>

      <!-- Footer -->
      <footer class="mt-12 pt-8 border-t border-zinc-800 text-center text-xs text-zinc-500">
        © {new Date().getFullYear()} Zachary Lewis
      </footer>

    </div>
  </body>
</html>
