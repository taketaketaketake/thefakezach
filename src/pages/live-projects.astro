---
import { liveProjects } from "../data/live-projects";

const statusDisplayMap: Record<string, string> = {
  "live": "Live",
  "in-progress": "In Progress",
  "paused": "Paused",
};

const pageTitle = "LIVE PROJECTS – Cosmic Crew Universe";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --aqua: #0EF2D4;
        --chartreuse: #CEF64D;
        --amber: #FFD55A;
        --navy: #0A214B;
        --indigo: #2B1A55;
        --pink: #FF0080;
        --cyan: #00FFFF;
      }

      body {
        background: linear-gradient(180deg, var(--navy), var(--indigo));
        color: white;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        overflow-x: hidden;
      }

      #canvas-container {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
      }

      .content-wrapper {
        position: relative;
        z-index: 10;
        min-height: 100vh;
      }

      .top-nav {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 2rem 0;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--aqua);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        opacity: 0.85;
        transition: all 0.2s ease;
      }

      .back-link:hover {
        opacity: 1;
        color: var(--pink);
      }

      .hero-section {
        text-align: center;
        padding: 4rem 2rem 3rem;
        background: linear-gradient(135deg, rgba(14, 242, 212, 0.08), rgba(255, 0, 128, 0.08));
      }

      .hero-title {
        font-size: clamp(3rem, 8vw, 6rem);
        font-weight: 900;
        background: linear-gradient(45deg, var(--aqua), var(--pink), var(--chartreuse));
        background-size: 200% 200%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradient-flow 3s ease-in-out infinite;
        margin-bottom: 1rem;
      }

      .hero-subtitle {
        font-size: clamp(1.2rem, 3vw, 2rem);
        color: var(--cyan);
        margin-bottom: 1.5rem;
        font-weight: 600;
      }

      .hero-description {
        max-width: 800px;
        margin: 0 auto;
        font-size: 1.15rem;
        color: #e2e8f0;
        opacity: 0.9;
      }

      .projects-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem 4rem;
      }

      .business-grid {
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .business-card {
        background: rgba(0, 0, 0, 0.6);
        border: 2px solid var(--aqua);
        border-radius: 1rem;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        cursor: pointer;
        display: grid;
        grid-template-columns: 1fr 260px;
        gap: 2rem;
        align-items: center;
        text-decoration: none;
        color: inherit;
      }

      .business-card:hover {
        transform: translateY(-6px) scale(1.01);
        border-color: var(--pink);
        background: rgba(0, 0, 0, 0.8);
        box-shadow: 0 20px 40px rgba(255, 0, 128, 0.3);
      }

      .business-content {
        padding: 2rem;
      }

      .business-image-container {
        padding: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .business-header {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
      }

      .business-emoji {
        font-size: 2.5rem;
        line-height: 1;
      }

      .business-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: white;
      }

      .business-year {
        background: var(--navy);
        color: var(--aqua);
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.85rem;
        font-weight: 600;
      }

      .business-tagline {
        color: var(--cyan);
        font-size: 1rem;
        font-weight: 500;
        margin-bottom: 1.25rem;
      }

      .business-summary {
        color: #e2e8f0;
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
      }

      .metric-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.75rem;
        margin-bottom: 1.5rem;
      }

      .metric-cell {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(14, 242, 212, 0.25);
        border-radius: 0.6rem;
        padding: 0.75rem;
      }

      .metric-cell-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--aqua);
        font-weight: 600;
        margin-bottom: 0.25rem;
      }

      .metric-cell-value {
        font-size: 1.5rem;
        font-weight: 800;
        color: white;
        line-height: 1;
        margin-bottom: 0.15rem;
      }

      .metric-cell-hint {
        font-size: 0.7rem;
        color: #94a3b8;
      }

      .open-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: linear-gradient(45deg, var(--pink), var(--cyan));
        color: white;
        padding: 0.6rem 1.2rem;
        border-radius: 0.5rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.85rem;
      }

      .business-image {
        width: 260px;
        height: 260px;
        object-fit: cover;
        border-radius: 1rem;
        border: 2px solid rgba(255, 255, 255, 0.2);
      }

      .emoji-fallback {
        width: 260px;
        height: 260px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.06);
        border: 2px dashed rgba(255, 255, 255, 0.18);
        color: white;
        font-size: 6rem;
        border-radius: 1rem;
      }

      .business-status {
        position: absolute;
        top: 1rem;
        right: 1rem;
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .status-live { background: var(--chartreuse); color: var(--navy); }
      .status-inprogress { background: var(--amber); color: var(--navy); }
      .status-paused { background: rgba(255, 255, 255, 0.2); color: white; }

      .floating-elements {
        position: absolute;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
      }

      .float-icon {
        position: absolute;
        font-size: 2rem;
        opacity: 0.1;
        animation: float 6s ease-in-out infinite;
      }

      @keyframes gradient-flow {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
      }

      @keyframes float {
        0%, 100% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(180deg); }
      }

      @media (max-width: 968px) {
        .business-card {
          grid-template-columns: 1fr;
        }

        .business-image-container {
          padding: 1.5rem;
          order: -1;
        }

        .business-image,
        .emoji-fallback {
          width: 100%;
          height: 200px;
          font-size: 5rem;
        }

        .metric-row {
          grid-template-columns: repeat(2, 1fr);
        }

        .hero-section {
          padding: 3rem 1rem 2rem;
        }
      }
    </style>
  </head>

  <body>
    <div id="canvas-container"></div>

    <div class="content-wrapper">
      <div class="floating-elements">
        <div class="float-icon" style="top: 10%; left: 5%; animation-delay: 0s;">🔥</div>
        <div class="float-icon" style="top: 20%; right: 10%; animation-delay: 2s;">🧺</div>
        <div class="float-icon" style="top: 60%; left: 8%; animation-delay: 4s;">🗺️</div>
        <div class="float-icon" style="bottom: 30%; right: 15%; animation-delay: 1s;">🩺</div>
        <div class="float-icon" style="bottom: 20%; left: 12%; animation-delay: 3s;">📊</div>
      </div>

      <div class="top-nav">
        <a href="/projects" class="back-link">← All Projects</a>
      </div>

      <div class="hero-section">
        <h1 class="hero-title">LIVE PROJECTS</h1>
        <p class="hero-subtitle">Businesses I'm running, in real time</p>
        <p class="hero-description">
          Each card is a real operating business. Metrics here are placeholders today — the data shape underneath each
          one declares where the live value will be read from once wired up.
        </p>
      </div>

      <div class="projects-container">
        <div class="business-grid">
          {liveProjects.map((p) => {
            const statusClass = `status-${p.status.replace("-", "")}`;
            const topMetrics = p.metrics.slice(0, 4);
            return (
              <a href={`/live-projects/${p.slug}`} class="business-card">
                <div class={`business-status ${statusClass}`}>
                  {statusDisplayMap[p.status]}
                </div>

                <div class="business-content">
                  <div class="business-header">
                    <span class="business-emoji">{p.emoji}</span>
                    <span class="business-title">{p.title}</span>
                    <span class="business-year">{p.year}</span>
                  </div>

                  <div class="business-tagline">{p.tagline}</div>

                  <div class="business-summary">{p.summary}</div>

                  <div class="metric-row">
                    {topMetrics.map((m) => (
                      <div class="metric-cell">
                        <div class="metric-cell-label">{m.label}</div>
                        <div class="metric-cell-value">{m.value}</div>
                        {m.hint && <div class="metric-cell-hint">{m.hint}</div>}
                      </div>
                    ))}
                  </div>

                  <span class="open-cta">Open Detail →</span>
                </div>

                <div class="business-image-container">
                  {p.image ? (
                    <img
                      src={p.image}
                      alt={p.title}
                      class="business-image"
                      style={p.imagePosition ? `object-position: ${p.imagePosition}` : undefined}
                    />
                  ) : (
                    <div class="emoji-fallback">{p.emoji}</div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <script>
      let scene, camera, renderer, starField;

      function init() {
        if (typeof THREE === "undefined") return;

        scene = new THREE.Scene();
        camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 2000);
        camera.position.set(0, 0, 100);

        renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setClearColor(0x0a214b, 1);

        const container = document.getElementById("canvas-container");
        if (!container) return;
        container.appendChild(renderer.domElement);

        const starGeometry = new THREE.BufferGeometry();
        const starVertices = [];
        const starColors = [];
        for (let i = 0; i < 500; i++) {
          starVertices.push(
            (Math.random() - 0.5) * 1000,
            (Math.random() - 0.5) * 800,
            -500 + Math.random() * 300
          );
          const b = 0.5 + Math.random() * 0.5;
          starColors.push(b, b, b);
        }
        starGeometry.setAttribute("position", new THREE.Float32BufferAttribute(starVertices, 3));
        starGeometry.setAttribute("color", new THREE.Float32BufferAttribute(starColors, 3));

        const starMaterial = new THREE.PointsMaterial({
          size: 2,
          transparent: true,
          opacity: 0.8,
          vertexColors: true,
          sizeAttenuation: true,
        });
        starField = new THREE.Points(starGeometry, starMaterial);
        scene.add(starField);

        window.addEventListener("resize", () => {
          renderer.setSize(window.innerWidth, window.innerHeight);
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
        });

        function animate() {
          requestAnimationFrame(animate);
          if (starField) {
            starField.rotation.y += 0.0001;
            starField.rotation.x += 0.0002;
          }
          renderer.render(scene, camera);
        }
        animate();
      }

      document.addEventListener("DOMContentLoaded", () => {
        const ready = () => {
          if (typeof THREE !== "undefined") init();
          else setTimeout(ready, 100);
        };
        ready();
      });
    </script>
  </body>
</html>
